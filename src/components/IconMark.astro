---
const { icon = 'person' } = Astro.props;
---
<span class="icon-mark">
  {icon === 'chart' && <svg viewBox="0 0 24 24" fill="none"><path d="M4 19V5m0 14h16M8 16v-5m4 5V8m4 8v-7" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>}
  {icon === 'message' && <svg viewBox="0 0 24 24" fill="none"><path d="M5 5h14v10H8l-3 4V5Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg>}
  {icon === 'measure' && <svg viewBox="0 0 24 24" fill="none"><path d="M12 3v18M5 8h14M5 16h14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>}
  {icon === 'grid' && <svg viewBox="0 0 24 24" fill="none"><path d="M4 7h16M7 4v16m10-16v16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>}
  {icon === 'data' && <svg viewBox="0 0 24 24" fill="none"><path d="M6 18h12M8 18V6h8v12M10 9h4M10 13h4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>}
  {!['chart', 'message', 'measure', 'grid', 'data'].includes(icon) && <svg viewBox="0 0 24 24" fill="none"><path d="M12 5a4 4 0 1 0 0 8 4 4 0 0 0 0-8ZM4 21a8 8 0 0 1 16 0" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>}
</span>
