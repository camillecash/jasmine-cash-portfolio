---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles.css';
import { siteTitle, siteDescription, siteUrl, socialImage } from '../content';

const {
  title = siteTitle,
  description = siteDescription,
  current = '',
  path = '/',
  bodyClass = ''
} = Astro.props;

const fullTitle = title === siteTitle ? `${siteTitle} | Clinical Researcher` : `${title} | ${siteTitle}`;
const canonical = `${siteUrl.replace(/\/$/, '')}/${path.replace(/^\//, '')}`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title === siteTitle ? siteTitle : `${title} | ${siteTitle}`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={socialImage} />
    <title>{fullTitle}</title>
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="assets/favicon.svg" type="image/svg+xml" />
  </head>
  <body class={bodyClass}>
    <Header current={current} />
    <slot />
    <Footer />
    <script is:inline src="/site.js"></script>
  </body>
</html>
