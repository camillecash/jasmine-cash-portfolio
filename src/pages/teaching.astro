---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import { teaching } from '../content';
const heroCopy = teaching.hero.description || teaching.hero.paragraphs?.join(' ');
---
<BaseLayout title="Teaching" description="Teaching and mentorship experience for Jasmine J. Cash, including Anatomy and Physiology instruction and student mentorship." current="teaching" path="teaching.html">
  <main>
    <section class="page-hero teaching-hero">
      <p class="eyebrow">{teaching.hero.eyebrow}</p>
      <h1>{teaching.hero.title}</h1>
      <p class="hero-copy">{heroCopy}</p>
    </section>

    <section class="page-main teaching-layout">
      <div class="teaching-summary">
        <p class="eyebrow">{teaching.summary.eyebrow}</p>
        <h2>{teaching.summary.title}</h2>
        <p>{teaching.summary.description}</p>
      </div>

      <div class="teaching-details">
        {(teaching.positions || []).map((position) => (
          <article class={`teaching-card${position.featured ? ' featured' : ''}`}>
            <div><span class="teaching-date">{position.date}</span><h3>{position.institution}</h3><p class="teaching-role">{position.role}</p></div>
            <p>{position.description}</p>
            <div class="course-list" aria-label={position.coursesLabel}>{position.courses?.map((course) => <span>{course}</span>)}</div>
          </article>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
