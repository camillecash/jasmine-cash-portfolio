---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import IconMark from '../components/IconMark.astro';
import { expertise } from '../content';
---
<BaseLayout title="Training and Expertise" description="Research training, expertise, education, credentials, and scholarly foundations for Jasmine J. Cash, PhD, CSCS." current="expertise" path="expertise.html">
  <main>
    <section class="page-hero">
      <p class="eyebrow">Research Profile</p>
      <h1>Training and expertise</h1>
      <p class="hero-copy">A concise view of Dr. Cash's education, research roles, dissertation and thesis work, methodological strengths, credentials, and scholarly service</p>
    </section>

    <section class="page-main skill-grid">
      {[...(expertise.skills || [])].sort((a, b) => (a.order ?? 0) - (b.order ?? 0)).map((skill) => (
        <article class="card">
          <IconMark icon={skill.icon} />
          <h3>{skill.title}</h3>
          <p>{skill.description}</p>
        </article>
      ))}
    </section>

    <section class="section profile-section">
      <div class="section-heading"><p class="eyebrow">Training and Experience</p><h2>Education and research roles</h2></div>
      <div class="profile-grid">
        {[...(expertise.profiles || [])].sort((a, b) => (a.order ?? 0) - (b.order ?? 0)).map((profile) => (
          <article class="profile-card">
            <h3>{profile.title}</h3>
            <div class="timeline compact-timeline">
              {[...(profile.items || [])].sort((a, b) => (a.order ?? 0) - (b.order ?? 0)).map((item) => (
                <article class="timeline-item"><span class="recognition-date">{item.date}</span><h4>{item.title}</h4><p>{item.description}</p></article>
              ))}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section scholarly-section">
      <div class="section-heading"><p class="eyebrow">Scholarly Foundations</p><h2>Dissertation, thesis, and manuscript review</h2></div>
      <div class="scholarly-grid">
        {[...(expertise.scholarly || [])].sort((a, b) => (a.order ?? 0) - (b.order ?? 0)).map((item) => (
          <article class="profile-card">
            <span class="recognition-date">{item.label}</span><h3>{item.title}</h3><p>{item.description}</p>
            <div class="meta-list">{item.tags?.map((tag) => <span class="pill">{tag}</span>)}</div>
          </article>
        ))}
        <article class="profile-card review-card">
          <h3>Manuscript review</h3>
          <ul class="recognition-bullets">{expertise.reviewJournals?.map((journal) => <li>{journal}</li>)}</ul>
        </article>
      </div>
    </section>

    <section class="section credential-section">
      <div class="section-heading"><p class="eyebrow">Credentials</p><h2>Licenses and certifications</h2></div>
      <div class="credential-grid">
        {[...(expertise.credentials || [])].sort((a, b) => (a.order ?? 0) - (b.order ?? 0)).map((credential) => (
          <article class="credential-card">
            <span class="recognition-date">{credential.date}</span><h3>{credential.title}</h3><p>{credential.issuer}</p>
            <div class="meta-list">{credential.tags?.map((tag) => <span class="pill">{tag}</span>)}</div>
          </article>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
